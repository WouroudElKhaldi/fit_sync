datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// ================= ENUMS =================

enum Role {
  USER
  TRAINER
  ADMIN
}

enum SetStatus {
  PENDING
  COMPLETED
  MODIFIED
  SKIPPED
}

enum MuscleTargetType {
  PRIMARY
  SECONDARY
}

enum WeightUnit {
  KG
  LB
}

enum LengthUnit {
  CM
  IN
}

// ================= USER & PROFILE =================

model User {
  id                      String          @id @default(uuid())
  email                   String          @unique
  username                String          @unique
  passwordHash            String
  fullName                String
  bio                     String?
  role                    Role            @default(USER)
  
  // Custom Measurement Units
  weightUnit              WeightUnit      @default(KG)
  lengthUnit              LengthUnit      @default(CM)
  
  // Notifications
  notificationLeadMinutes Int             @default(60)

  // Authentication Lifecycle & Verification
  isVerified              Boolean         @default(false)
  verificationCode        String?
  resetPasswordCode       String?

  createdAt               DateTime        @default(now())
  updatedAt               DateTime        @updatedAt

  // Trainer/Client Relationship (Self-reference)
  trainerId               String?
  trainer                 User?           @relation("TrainerClients", fields: [trainerId], references: [id])
  clients                 User[]          @relation("TrainerClients")

  // App Modules
  trainerProfile          TrainerProfile?
  biometrics              BiometricLog[]
  workoutPlans            WorkoutPlan[]   @relation("ClientWorkouts")
  createdPlans            WorkoutPlan[]   @relation("CreatedWorkouts")
  sentMessages            Message[]       @relation("SentMessages")
  receivedMessages        Message[]       @relation("ReceivedMessages")

  // Chat Groups
  createdGroups           ChatGroup[]     @relation("CreatedGroups")
  groupMemberships        ChatGroupMember[]

  // Connections
  requestedConnections    Connection[]    @relation("RequestedConnections")
  receivedConnections     Connection[]    @relation("ReceivedConnections")

  // Chat History Management (Soft Delete)
  clearedChats            ChatClear[]

  // Blocks
  blockingUsers           Block[]         @relation("BlockingUsers")
  blockedUsers            Block[]         @relation("BlockedUsers")

  // Presence Status
  isOnline                Boolean         @default(false)
  lastActiveAt            DateTime        @default(now())
}

model TrainerProfile {
  id                String    @id @default(uuid())
  userId            String    @unique
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  bio               String?
  education         String?   // Added per requirement
  certifications    String[]
  specialties       String[]
  rating            Float     @default(0.0)
  reviewCount       Int       @default(0)
  marketplaceActive Boolean   @default(true)
}

// ================= EXERCISE DICTIONARY =================

model Equipment {
  id        String     @id @default(uuid())
  name      String     @unique // e.g., Barbell, Cable Machine
  exercises Exercise[]
}

model Muscle {
  id        String           @id @default(uuid())
  name      String           @unique // e.g., Pectoralis Major
  category  String           // e.g., Chest, Back, Legs
  exercises ExerciseMuscle[]
}

model Exercise {
  id          String            @id @default(uuid())
  name        String            @unique
  description String?
  steps       String[]          // Sequential instructions
  equipmentId String?
  equipment   Equipment?        @relation(fields: [equipmentId], references: [id])
  muscles     ExerciseMuscle[]
  workouts    WorkoutExercise[]
}

model ExerciseMuscle {
  exerciseId String
  muscleId   String
  targetType MuscleTargetType  // PRIMARY | SECONDARY
  exercise   Exercise          @relation(fields: [exerciseId], references: [id], onDelete: Cascade)
  muscle     Muscle            @relation(fields: [muscleId], references: [id], onDelete: Cascade)

  @@id([exerciseId, muscleId])
}

// ================= WORKOUT LOGIC =================

model WorkoutPlan {
  id             String            @id @default(uuid())
  title          String            // e.g., "Monday Pull Day"
  description    String?
  scheduledDate  DateTime?         // Specific date/time
  isRecurring    Boolean           @default(false)
  recurrenceRule String?           // RRULE format
  
  createdById    String
  createdBy      User              @relation("CreatedWorkouts", fields: [createdById], references: [id], onDelete: Cascade)
  
  clientId       String
  client         User              @relation("ClientWorkouts", fields: [clientId], references: [id], onDelete: Cascade)
  
  exercises      WorkoutExercise[]
  session        WorkoutSession?
  createdAt      DateTime          @default(now())

  // Linked Messages
  linkedMessages Message[]         @relation("LinkedMessages")
}

model WorkoutExercise {
  id            String       @id @default(uuid())
  workoutPlanId String
  workoutPlan   WorkoutPlan  @relation(fields: [workoutPlanId], references: [id], onDelete: Cascade)
  exerciseId    String
  exercise      Exercise     @relation(fields: [exerciseId], references: [id])
  
  orderIndex    Int          // Sequence: 1, 2, 3...
  restTimeSec   Int?         // Added per requirement (Break time)
  notes         String?
  
  sets          WorkoutSet[]
}

model WorkoutSet {
  id                 String          @id @default(uuid())
  workoutExerciseId  String
  workoutExercise    WorkoutExercise @relation(fields: [workoutExerciseId], references: [id], onDelete: Cascade)
  setIndex           Int

  // The Plan (Targets)
  expectedReps       Int
  expectedWeight     Float           
  
  // The Execution (Actuals)
  actualReps         Int?
  actualWeight       Float?
  status             SetStatus       @default(PENDING)
  
  // Link to specific session execution
  workoutSessionId   String?
  workoutSession     WorkoutSession? @relation(fields: [workoutSessionId], references: [id], onDelete: Cascade)
}

model WorkoutSession {
  id              String       @id @default(uuid())
  workoutPlanId   String       @unique
  workoutPlan     WorkoutPlan  @relation(fields: [workoutPlanId], references: [id], onDelete: Cascade)
  
  startedAt       DateTime     @default(now())
  completedAt     DateTime?
  
  totalVolume     Float        @default(0.0)
  clientNotes     String?      // Struggles / Comments
  trainerFeedback String?
  trainerRating   Int?         // 1-5 Scale
  
  loggedSets      WorkoutSet[]
}

// ================= BIOMETRICS & CHAT =================

model BiometricLog {
  id       String   @id @default(uuid())
  userId   String
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  weight   Float    
  height   Float?   
  loggedAt DateTime @default(now())
}

enum GroupInvitationStatus {
  PENDING
  ACCEPTED
  REJECTED
}

model ChatGroup {
  id             String            @id @default(uuid())
  name           String
  createdById    String
  createdBy      User              @relation("CreatedGroups", fields: [createdById], references: [id], onDelete: Cascade)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  members        ChatGroupMember[]
  messages       Message[]         @relation("GroupMessages")
}

model ChatGroupMember {
  id           String                @id @default(uuid())
  groupId      String
  group        ChatGroup             @relation(fields: [groupId], references: [id], onDelete: Cascade)
  userId       String
  user         User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  status       GroupInvitationStatus @default(PENDING)
  joinedAt     DateTime?
  createdAt    DateTime              @default(now())

  @@unique([groupId, userId])
}

model Message {
  id            String       @id @default(uuid())
  senderId      String
  sender        User         @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  receiverId    String?
  receiver      User?        @relation("ReceivedMessages", fields: [receiverId], references: [id], onDelete: Cascade)
  groupId       String?
  group         ChatGroup?   @relation("GroupMessages", fields: [groupId], references: [id], onDelete: Cascade)
  content       String
  isRead        Boolean      @default(false)
  workoutPlanId String?
  workoutPlan   WorkoutPlan? @relation("LinkedMessages", fields: [workoutPlanId], references: [id], onDelete: SetNull)
  createdAt     DateTime     @default(now())
}

enum ConnectionStatus {
  PENDING
  ACCEPTED
  REJECTED
}

model Connection {
  id           String           @id @default(uuid())
  requesterId  String
  requester    User             @relation("RequestedConnections", fields: [requesterId], references: [id], onDelete: Cascade)
  addresseeId  String
  addressee    User             @relation("ReceivedConnections", fields: [addresseeId], references: [id], onDelete: Cascade)
  status       ConnectionStatus @default(PENDING)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  @@unique([requesterId, addresseeId])
}

// ================= CHAT CLEAR & BLOCKING =================

model ChatClear {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  otherUserId String?  // For direct chats
  groupId     String?  // For group chats
  clearedAt   DateTime @default(now())

  // A user can clear a specific direct chat or a specific group chat
  // Note: Only one entry per combination is needed, we just update clearedAt.
  @@unique([userId, otherUserId])
  @@unique([userId, groupId])
}

model Block {
  id        String   @id @default(uuid())
  blockerId String
  blocker   User     @relation("BlockingUsers", fields: [blockerId], references: [id], onDelete: Cascade)
  blockedId String
  blocked   User     @relation("BlockedUsers", fields: [blockedId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([blockerId, blockedId])
}
